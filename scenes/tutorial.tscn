[node name="GoalSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/GoalSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(1.0, 0.9, 0.25, 1)
text = "Your Goal"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/GoalSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Accumulate 8000 credits AND visit all 7 planets to win the game. Trade goods, complete quest chains, win battles, and explore the galaxy to reach your goal. Your faction reputation, debt pressure, and hull condition all affect how risky your run becomes. If your hull reaches zero, the game is over."
autowrap_mode = 3
mouse_filter = 2

[node name="PlanetScreenSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/PlanetScreenSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.0, 0.85, 0.95, 1)
text = "Planet View"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/PlanetScreenSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Each planet has a city map with clickable buildings. Click on a building to open it. Available buildings vary by planet type: Market (buy/sell goods), Shipyard (repairs, upgrades, new ships), Casino (gamble for credits), Crew (recruit crew members), Quest Board (accept delivery missions), Armory (view your deck), and Starport (depart to another planet). Some buildings are only available on certain planet types."
autowrap_mode = 3
mouse_filter = 2

[node name="TradingSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/TradingSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.0, 0.85, 0.45, 1)
text = "Trading"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/TradingSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Buy goods cheaply at one planet and sell them at another for profit. Different planet types affect prices - Agricultural planets sell food cheaply, while Industrial planets pay more for it. Your local faction reputation now modifies market prices too: good standing improves buy/sell rates, bad standing makes trade worse."
autowrap_mode = 3
mouse_filter = 2

[node name="NavigationSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/NavigationSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.0, 0.65, 0.95, 1)
text = "Navigation"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/NavigationSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Click on connected planets in the Galaxy Map to travel. Each journey may trigger a random encounter based on the route's danger level. Higher danger means more encounters but also better trading opportunities."
autowrap_mode = 3
mouse_filter = 2

[node name="CombatSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/CombatSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.95, 0.25, 0.35, 1)
text = "Card Combat"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/CombatSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "When you encounter enemies, you fight using cards. Each turn you draw cards and spend energy to play them. Attack cards deal damage, Defense cards raise your shield, Utility cards heal or draw more cards, and Trade cards earn credits. Your shield absorbs damage before your hull takes hits."
autowrap_mode = 3
mouse_filter = 2

[node name="CrewSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/CrewSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.6, 0.4, 1.0, 1)
text = "Crew"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/CrewSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Recruit up to 3 crew members at the Crew building on each planet. Each crew member provides a passive bonus: reduced encounter chance, attack bonus in combat, hull regeneration on arrival, better sell prices, smuggle protection against fines, or increased max hull. Different crew are available depending on the planet type. You can dismiss crew to make room for new ones."
autowrap_mode = 3
mouse_filter = 2

[node name="UpgradesSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/UpgradesSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(1.0, 0.9, 0.25, 1)
text = "Ship Upgrades"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/UpgradesSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Visit the Shipyard to repair your hull, improve your ship stats, or buy a new ship entirely. Upgrades can increase hull, shields, cargo capacity, energy, or add new cards to your deck. The Ship Dealer lets you trade in your current ship for a different model with unique stats and bonuses."
autowrap_mode = 3
mouse_filter = 2

[node name="ContrabandSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/ContrabandSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.85, 0.1, 0.38, 1)
text = "Contraband"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/ContrabandSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Spice and Stolen Tech are contraband goods only available at Outlaw planets. They sell at premium prices but carrying them increases your risk of patrol encounters. Selling contraband at lawful worlds hurts local reputation and can make future trade and travel harder."
autowrap_mode = 3
mouse_filter = 2

[node name="QuestChainSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/QuestChainSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.45, 0.9, 0.75, 1)
text = "Quest Chains & Reputation"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/QuestChainSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Quest contracts can now be multi-stage chains (Stage 1-3). Completing a stage can immediately assign the next stage with better rewards. Each quest has an issuing faction: success improves that faction reputation, while failed deadlines reduce it."
autowrap_mode = 3
mouse_filter = 2

[node name="LoanSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/LoanSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(1, 0.72, 0.18, 1)
text = "Loans & Debt"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/LoanSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "At the Quest building, you can take a loan for quick capital. Debt accrues interest each trip. If you miss repayment at maturity, collectors will drain credits, damage hull, and reduce lawful faction reputation. Debt pressure also increases encounter risk."
autowrap_mode = 3
mouse_filter = 2

[node name="DifficultySection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/DifficultySection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.3, 0.85, 1.0, 1)
text = "Difficulty"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/DifficultySection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "When starting a new game, choose your difficulty level. Easy mode gives you more starting credits (1500), extra hull, fewer encounters, and longer quest deadlines. Normal mode is the standard experience (1000 credits). Hard mode starts you with only 600 credits, less hull, more encounters, and shorter deadlines. Your difficulty is saved with your game."
autowrap_mode = 3
mouse_filter = 2

[node name="TravelEventsSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/TravelEventsSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.5, 0.8, 1.0, 1)
text = "Travel Events"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/TravelEventsSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "During travel between planets, you may encounter random non-combat events. A stranded trader might ask for help, you could discover an abandoned wreck to salvage, or pick up a distress signal. Each event offers two choices with different risks and rewards. Outcomes are not always guaranteed — helping a stranded trader could turn out to be a pirate trap, and salvaging a wreck might cause hull damage. Weigh the risk before choosing!"
autowrap_mode = 3
mouse_filter = 2

[node name="BountySection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/BountySection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(1.0, 0.4, 0.3, 1)
text = "Bounty System"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/BountySection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Illegal activities build up a bounty on your head. Getting caught smuggling adds 100 cr to your bounty. Defeating a System Patrol adds 50 cr. Once your bounty reaches 100 cr, you'll face more encounters and bounty hunters will start tracking you. At 300 cr, the heat gets even worse. You can reduce your bounty by defeating bounty hunters (-150 cr each) or pay it off entirely at the Quest Board. Your bounty is shown in the status bar when active."
autowrap_mode = 3
mouse_filter = 2

[node name="TradeLoyaltySection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/TradeLoyaltySection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.4, 0.9, 0.6, 1)
text = "Trade Loyalty"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/TradeLoyaltySection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Each trade at a planet increases your local Trade Loyalty (0-100). Higher loyalty gives you better prices: up to -8% on purchases and +6% on sales. Getting caught smuggling at a planet drops your loyalty by 15 points. Build loyalty at your favorite trading hubs for the best deals!"
autowrap_mode = 3
mouse_filter = 2

[node name="CustomsScanSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/CustomsScanSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.9, 0.3, 0.2, 1)
text = "Customs & Smuggling"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/CustomsScanSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Landing on non-Outlaw planets with contraband (Spice, Stolen Tech) in your cargo risks a customs inspection (20% chance). If caught, you have three options: Pay a Fine (lose credits + bounty + contraband confiscated), Try to Hide (chance-based, failure means harsher penalties), or Bribe the Official (costs double but no bounty on success). The Cloaking Device upgrade and Smuggle Protection crew reduce scan chances. When caught in a smuggler deal, you now also get bribery options."
autowrap_mode = 3
mouse_filter = 2

[node name="AchievementsSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/AchievementsSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(1.0, 0.9, 0.25, 1)
text = "Achievements"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/AchievementsSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "There are 12 achievements to unlock across all your playthroughs. Achievements are global — they persist even when you start a new game. Win battles, complete trades, explore planets, build your crew, and more. Check your progress from the Achievements button on the main menu. A notification pops up when you unlock a new achievement."
autowrap_mode = 3
mouse_filter = 2

[node name="HotkeysSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/HotkeysSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.7, 0.85, 1.0, 1)
text = "Keyboard Shortcuts"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/HotkeysSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "On the planet screen you can use keyboard shortcuts to quickly open buildings:

M - Market    S - Shipyard    K - Casino
C - Crew    Q - Quest Board    D - Deck Viewer
I - Mission    G - Galaxy Map / Depart    L - Event Log
ESC - Close current overlay

Space Invaders mini-game controls:
A / Left Arrow - Move left    D / Right Arrow - Move right
Space / Enter - Shoot"
autowrap_mode = 3
mouse_filter = 2

[node name="TipsSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/TipsSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(1.0, 0.75, 0.1, 1)
text = "Tips"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/TipsSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Start by trading between nearby safe planets to build credits. Buy upgrades early to make combat easier. Keep some credits in reserve for repairs. Build your deck strategically - too many cards dilute your best ones. Recruit crew early for their passive bonuses."
autowrap_mode = 3
mouse_filter = 2

