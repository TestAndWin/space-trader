text = "Navigation"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/NavigationSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Click on connected planets in the Galaxy Map to travel. Each journey may trigger a random encounter based on the route's danger level. Higher danger means more encounters but also better trading opportunities."
autowrap_mode = 3
mouse_filter = 2

[node name="CombatSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/CombatSection"]
layout_mode = 2
