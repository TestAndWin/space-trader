mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/UpgradesSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Visit the Upgrades shop on planets to improve your ship. Upgrades can increase hull, shields, cargo capacity, or add new cards to your deck. Different planet types offer different upgrades - Tech planets have the widest selection."
autowrap_mode = 3
mouse_filter = 2

