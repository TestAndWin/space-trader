[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/TradingSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Buy goods cheaply at one planet and sell them at another for profit. Different planet types affect prices - Agricultural planets sell food cheaply, while Industrial planets pay more for it. Watch the price colors: green means profitable, red means you'll lose money."
autowrap_mode = 3
mouse_filter = 2

[node name="NavigationSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
