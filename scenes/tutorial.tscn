mouse_filter = 2
theme_override_constants/separation = 16

[node name="GoalSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/GoalSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(1.0, 0.9, 0.25, 1)
text = "Your Goal"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/GoalSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Accumulate 8000 credits AND visit all 7 planets to win the game. Trade goods, complete quest chains, win battles, and explore the galaxy to reach your goal. Reputation, local trade loyalty, bounty pressure, debt, and active world events all shape how risky or profitable your run becomes. If your hull reaches zero, the game is over."
autowrap_mode = 3
mouse_filter = 2

[node name="PlanetScreenSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/PlanetScreenSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.0, 0.85, 0.95, 1)
text = "Planet View"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/PlanetScreenSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Each planet has a city map with clickable buildings. Click on a building to open it. Available buildings vary by planet type: Market (buy/sell goods), Shipyard (repairs, upgrades, new ships), Casino (gamble for credits), Crew (recruit crew members), Quest Board (accept delivery missions), Armory (view your deck), and Starport (depart to another planet). The header and status bars now also show the local faction, your reputation tier, loyalty tier, bounty status, and important local warnings such as patrol pressure or trader discounts."
autowrap_mode = 3
mouse_filter = 2

[node name="TradingSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/TradingSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.0, 0.85, 0.45, 1)
text = "Trading"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/TradingSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Buy goods cheaply at one planet and sell them at another for profit. Different planet types affect prices, but markets are also modified by faction reputation, local trade loyalty, service fees, and active world events. Market tooltips show a price breakdown and remember the best buy/sell prices you have seen so far. After you have compared at least two markets, especially good known prices are marked directly in the list."
autowrap_mode = 3
mouse_filter = 2

[node name="NavigationSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/NavigationSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.0, 0.65, 0.95, 1)
text = "Navigation"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/NavigationSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Click on connected planets in the Galaxy Map to travel. Each journey may trigger a random encounter based on the route's danger level, but bounty, contraband, debt pressure, local standing, and active world events can push the risk higher or lower. Planet hover info and travel warnings help you spot dangerous patrol routes, shortages, or smuggling opportunities before you launch."
autowrap_mode = 3
mouse_filter = 2

[node name="CombatSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/CombatSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.95, 0.25, 0.35, 1)
text = "Card Combat"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/CombatSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "When you encounter enemies, you fight using cards. Each turn you draw cards and spend energy to play them. Attack cards deal damage, Defense cards raise your shield, Utility cards heal or draw more cards, and Trade cards earn credits. Your shield absorbs damage before your hull takes hits."
autowrap_mode = 3
mouse_filter = 2

[node name="RivalSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/RivalSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(1.0, 0.35, 0.2, 1)
text = "Rival: Captain Vex"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/RivalSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "After enough flights, the notorious pirate Captain Vex will intercept you. He grows stronger with each encounter — four phases in total, triggered roughly every three flights. Defeating him always awards a ship upgrade. Survive all four phases and the rivalry ends for good, with a large credit bonus. Losing a fight only delays his return briefly, so be prepared before departing if your hull is low. A crew member with combat experience deals bonus damage against him."
autowrap_mode = 3
mouse_filter = 2

[node name="CrewSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/CrewSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.6, 0.4, 1.0, 1)
text = "Crew"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/CrewSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Recruit up to 3 crew members at the Crew building on each planet. Each crew member has a primary bonus (shown in the crew list) and a secondary bonus (shown below it in smaller text). Primary bonuses include reduced encounter chance, attack bonus in combat, hull regeneration, better sell prices, or protection against smuggling fines. Secondary bonuses improve event success chances, quest terms, or combat dodge. Different crew are available depending on the planet type. Some ships have a synergy with a specific crew type — if your ship and crew match, that crew's primary bonus is 50% more effective. The Scout amplifies all crew bonuses by 20%."
autowrap_mode = 3
mouse_filter = 2

[node name="UpgradesSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/UpgradesSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(1.0, 0.9, 0.25, 1)
text = "Ship Upgrades"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/UpgradesSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Visit the Shipyard to repair your hull, improve your ship stats, or buy a new ship entirely. Upgrades can increase hull, shields, cargo capacity, energy, or add new cards to your deck. Every ship also has a unique active ability shown with a ⚡ symbol in the Ship Dealer — for example the Warship deals bonus damage on the first attack of each turn when hull is high, the Smuggler can slip past one encounter per flight, the Freighter gets a bulk discount when buying large quantities, and the Explorer improves your odds in non-combat events. Match your ship with the right crew for a synergy bonus."
autowrap_mode = 3
mouse_filter = 2

[node name="ContrabandSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/ContrabandSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.85, 0.1, 0.38, 1)
text = "Contraband"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/ContrabandSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Spice and Stolen Tech are contraband goods mainly available at Outlaw planets. They can sell for huge profits, but carrying them increases patrol pressure and selling them at lawful worlds damages local standing, lowers loyalty, and can push your bounty higher. Contraband runs are strongest when the galaxy enters a smuggling-friendly event window, but that also tends to raise risk."
autowrap_mode = 3
mouse_filter = 2

[node name="QuestChainSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/QuestChainSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.45, 0.9, 0.75, 1)
text = "Quest Chains & Reputation"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/QuestChainSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Quest contracts can be multi-stage chains (Stage 1-3). Completing a stage can immediately assign the next stage with better rewards. Offers now depend on faction reputation, local loyalty, bounty status, and active world events: good standing improves terms and follow-up chances, while hostile or highly wanted pilots can be denied lawful contracts entirely. Reputation is faction-wide: it mainly rises by completing that faction's quests, and falls through failed deadlines, customs trouble, failed bribery, contraband sales on lawful worlds, and other hostile actions. Event-driven jobs also try to match the current situation, such as relief runs into shortage worlds or riskier smuggling routes during a window."
autowrap_mode = 3
mouse_filter = 2

[node name="LoanSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/LoanSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(1, 0.72, 0.18, 1)
text = "Loans & Debt"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/LoanSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "At the Quest building, you can take a loan for quick capital. Debt accrues interest each trip. If you miss repayment at maturity, collectors will drain credits, damage hull, and reduce lawful faction reputation. Debt pressure also increases encounter risk."
autowrap_mode = 3
mouse_filter = 2

[node name="DifficultySection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/DifficultySection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.3, 0.85, 1.0, 1)
text = "Difficulty"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/DifficultySection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "When starting a new game, choose your difficulty level. Easy mode gives you more starting credits (1500), extra hull, fewer encounters, and longer quest deadlines. Normal mode is the standard experience (1000 credits). Hard mode starts you with only 600 credits, less hull, more encounters, and shorter deadlines. Your difficulty is saved with your game."
autowrap_mode = 3
mouse_filter = 2

[node name="TravelEventsSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/TravelEventsSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.5, 0.8, 1.0, 1)
text = "Travel & World Events"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/TravelEventsSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "During travel between planets, you may encounter random non-combat events. A stranded trader might ask for help, you could discover an abandoned wreck to salvage, or pick up a distress signal. The wider galaxy can also enter chained world events such as blockades, shortages, smuggling windows, tech theft, and security crackdowns. These chains affect prices, quest quality, route danger, and the warning text shown before travel."
autowrap_mode = 3
mouse_filter = 2

[node name="BountySection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/BountySection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(1.0, 0.4, 0.3, 1)
text = "Bounty System"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/BountySection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Illegal activities build up a bounty on your head. Your status moves through tiers such as Watched, Wanted, and Most Wanted. Higher tiers raise encounter pressure, make bounty hunters more likely, increase local friction and fees on lawful worlds, and can block or worsen contract offers. You can reduce your bounty by defeating bounty hunters or pay it off entirely at the Quest Board."
autowrap_mode = 3
mouse_filter = 2

[node name="TradeLoyaltySection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/TradeLoyaltySection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.4, 0.9, 0.6, 1)
text = "Trade Loyalty"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/TradeLoyaltySection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Each legal trade at a planet increases your local Trade Loyalty. Loyalty is local to that specific world and tiers progress from Unknown to Known, Regular, Preferred, and Local Hero. Higher loyalty improves prices, reduces some local friction, and can make authorities more lenient. Loyalty mainly goes up through repeated legal buying and selling on the same planet, and larger trades build it faster than tiny ones. It goes down when you sell contraband there, get caught by customs, or fail smuggling and bribery attempts on that world."
autowrap_mode = 3
mouse_filter = 2

[node name="CustomsScanSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/CustomsScanSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.9, 0.3, 0.2, 1)
text = "Customs & Smuggling"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/CustomsScanSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Landing on non-Outlaw planets with contraband (Spice, Stolen Tech) in your cargo risks a customs inspection. Scan chance, fine size, hide chance, and bribe success are now shaped by faction standing, local loyalty, bounty tier, crew bonuses, and cloaking. If caught, you can pay the fine, try to hide the cargo, or bribe the official. Friendly worlds may only warn you, while bad standing or failed tricks can lead to confiscation, harsher penalties, loyalty loss, and extra bounty."
autowrap_mode = 3
mouse_filter = 2

[node name="AchievementsSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/AchievementsSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(1.0, 0.9, 0.25, 1)
text = "Achievements"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/AchievementsSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "There are 12 achievements to unlock across all your playthroughs. Achievements are global — they persist even when you start a new game. Win battles, complete trades, explore planets, build your crew, and more. Check your progress from the Achievements button on the main menu. A notification pops up when you unlock a new achievement."
autowrap_mode = 3
mouse_filter = 2

[node name="HotkeysSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/HotkeysSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.7, 0.85, 1.0, 1)
text = "Keyboard Shortcuts"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/HotkeysSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "On the planet screen you can use keyboard shortcuts to quickly open buildings:

M - Market    S - Shipyard    K - Casino
C - Crew    Q - Quest Board    D - Deck Viewer
I - Mission    G - Galaxy Map / Depart    L - Event Log
ESC - Close current overlay

Space Invaders mini-game controls:
A / Left Arrow - Move left    D / Right Arrow - Move right
Space / Enter - Shoot"
autowrap_mode = 3
mouse_filter = 2

[node name="TipsSection" type="VBoxContainer" parent="VBoxContainer/ScrollContainer/ContentVBox"]
layout_mode = 2
mouse_filter = 2

[node name="Title" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/TipsSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(1.0, 0.75, 0.1, 1)
text = "Tips"
mouse_filter = 2

[node name="Body" type="Label" parent="VBoxContainer/ScrollContainer/ContentVBox/TipsSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Start by learning a few safe routes and building credits before pushing contraband or high-danger travel. Use market tooltips and galaxy-map hints to build your own trade logbook, and keep at least one lawful faction on good terms so you always have a stable route for repairs and contracts. Watch event banners closely: shortages, crackdowns, and smuggling windows can create huge profit spikes, but only if your ship, bounty, and crew can survive the extra heat."
autowrap_mode = 3
mouse_filter = 2

[node name="BottomSeparator" type="HSeparator" parent="VBoxContainer"]
layout_mode = 2
mouse_filter = 2

[node name="BackButton" type="Button" parent="VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(200, 40)
size_flags_horizontal = 4
text = "Back"
